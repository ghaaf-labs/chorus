{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.dev/schemas/refactor-scribe.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "steps"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "needs-attention", "inconclusive"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["op", "file", "line_start", "line_end", "rationale", "inverse"],
        "properties": {
          "op": { "type": "string", "minLength": 1 },
          "file": { "type": "string", "minLength": 1 },
          "line_start": { "type": "integer", "minimum": 1 },
          "line_end": { "type": "integer", "minimum": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "inverse": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
