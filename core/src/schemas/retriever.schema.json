{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.dev/schemas/retriever.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "chunks", "confidence"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "needs-attention", "inconclusive"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "score", "excerpt"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "score": { "type": "number" },
          "excerpt": { "type": "string" },
          "heading_path": { "type": "array", "items": { "type": "string" } },
          "doc_type": { "type": "string" }
        }
      }
    }
  }
}
