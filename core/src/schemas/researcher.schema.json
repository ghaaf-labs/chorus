{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.dev/schemas/researcher.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "answers", "unknowns", "recommended_next_steps"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "needs-attention", "inconclusive"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "answers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "confidence", "sources"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "confidence": {
            "type": "string",
            "enum": ["established", "plausible", "speculative"]
          },
          "sources": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_next_steps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
