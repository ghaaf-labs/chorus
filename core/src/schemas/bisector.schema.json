{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.dev/schemas/bisector.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "candidates", "bisect_plan"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "needs-attention", "inconclusive"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sha", "rank", "suspicion", "rationale"],
        "properties": {
          "sha": { "type": "string", "minLength": 1 },
          "rank": { "type": "integer", "minimum": 1 },
          "suspicion": { "type": "string", "enum": ["high", "medium", "low"] },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "bisect_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "test_sha", "rationale"],
        "properties": {
          "step": { "type": "integer", "minimum": 1 },
          "test_sha": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
