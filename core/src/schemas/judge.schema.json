{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus.dev/schemas/judge.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "merged_verdict", "reasoning", "sourced_from"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "needs-attention", "inconclusive"]
    },
    "merged_verdict": {
      "type": "string",
      "enum": ["approve", "needs-attention", "inconclusive"]
    },
    "reasoning": { "type": "string", "minLength": 1 },
    "sourced_from": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target", "verdict"],
        "properties": {
          "target": { "type": "string" },
          "verdict": { "type": "string" },
          "weight": { "type": "number" },
          "quote": { "type": "string" }
        }
      }
    },
    "dissent_acknowledged": { "type": "string" }
  }
}
