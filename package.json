{
  "name": "@chorus/cli",
  "version": "0.1.0-dev",
  "description": "Multi-CLI agent collaboration toolkit. Lets Claude Code, OpenAI Codex CLI, xAI Grok CLI, and OpenCode call each other for review, research, planning, and adversarial critique without poisoning the calling agent's context.",
  "type": "module",
  "bin": {
    "chorus": "./bin/chorus",
    "chorus-core": "./core/bin/chorus-core.mjs"
  },
  "exports": {
    ".": "./core/src/cli.mjs"
  },
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run core/test/unit",
    "test:e2e:stub": "vitest run tests/e2e",
    "test:e2e:live": "CHORUS_E2E_LIVE=1 vitest run tests/e2e",
    "lint": "eslint . --ext .mjs,.js",
    "prepack": "node scripts/postpack.mjs",
    "postpack": "node scripts/restore-symlinks.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/ghaaf/chorus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ghaaf/chorus.git"
  },
  "keywords": [
    "claude-code",
    "codex",
    "grok",
    "opencode",
    "multi-agent",
    "agent-orchestration",
    "mcp",
    "ai-agents"
  ]
}
